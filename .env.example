# ─── Next.js app (Vercel project #1, root directory: ./) ───────────────────

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — TEST MODE keys only (sk_test_..., whsec_...)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Encrypts users' model API keys at rest. Changing it invalidates saved keys.
# Generate with: openssl rand -base64 32
ENCRYPTION_SECRET=

COUPON_CODE=SID_DRDROID

# No trailing slash. Used for Stripe redirect URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# The Python LangGraph service (Vercel project #2). No trailing slash.
AGENT_SERVICE_URL=http://localhost:8000
# Shared secret for the server-to-server call. openssl rand -base64 32
AGENT_SERVICE_SECRET=


# ─── Agent service (Vercel project #2, root directory: ./agent-service) ────
# Set these on that project, not on the Next.js one.
#
#   SUPABASE_URL=https://YOUR_PROJECT.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY=
#   TAVILY_API_KEY=              # also used for the Tavily MCP connection
#   AGENT_SERVICE_SECRET=        # must match the value above
